{
  "manifest_version": 3,
  "name": "DrainStop",
  "version": "1.0",
  "description": "Stop the drain before it starts.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["storage", "notifications", "tabs"],
  "host_permissions": ["<all_urls>"]
}
